---
import '../styles/global.css';
import { withBase } from '../lib/paths';
import { siteContact, siteTagline } from '../lib/site';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'GlobalPulse',
	description = siteTagline,
} = Astro.props;

const pageTitle = title === 'GlobalPulse' ? title : `${title} · GlobalPulse`;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={withBase('favicon.svg')} />
		<link rel="icon" href={withBase('favicon.ico')} sizes="any" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{pageTitle}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,700&family=Noto+Sans:ital,wght@0,400;0,600;1,400&family=Noto+Sans+SC:wght@400;600&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<div class="page-shell">
			<header class="site-header">
				<a class="brand" href={withBase()}>GlobalPulse</a>
				<nav class="site-nav" aria-label="Primary">
					<a href={withBase()}>Today</a>
					<a href={withBase('archive')}>Archive</a>
				</nav>
			</header>
			<main>
				<slot />
			</main>
			<footer class="site-footer">
				<p>
					Automated news aggregation from around the world. Content on this site is compiled
					automatically from third-party sources and is not independently verified. We make no
					representation or warranty as to the accuracy, completeness, or timeliness of any
					information shown here. Links to external websites are provided for convenience only; we
					do not control those sites and accept no responsibility or liability for their content or
					for any loss or damage arising from your use of this site or of linked third-party
					material.
				</p>
				<p class="site-footer__credit">
					© {siteContact.name}, {siteContact.location}
				</p>
			</footer>
		</div>
	</body>
</html>
