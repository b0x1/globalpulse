---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'GlobalPulse',
	description = 'News in English, German, Chinese, and French — from the language of the land.',
} = Astro.props;

const pageTitle = title === 'GlobalPulse' ? title : `${title} · GlobalPulse`;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{pageTitle}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,700&family=Noto+Sans:ital,wght@0,400;0,600;1,400&family=Noto+Sans+SC:wght@400;600&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<div class="page-shell">
			<header class="site-header">
				<a class="brand" href="/">GlobalPulse</a>
				<nav class="site-nav" aria-label="Primary">
					<a href="/">Today</a>
					<a href="/archive">Archive</a>
				</nav>
			</header>
			<main>
				<slot />
			</main>
			<footer class="site-footer">
				<p>English, German, Chinese, French — one pulse around the globe.</p>
			</footer>
		</div>
	</body>
</html>
