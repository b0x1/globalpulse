---
import '../styles/global.css';
import { withBase } from '../lib/paths';
import { siteContact, siteTagline } from '../lib/site';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'GlobalPulse',
	description = siteTagline,
} = Astro.props;

const pageTitle = title === 'GlobalPulse' ? title : `${title} · GlobalPulse`;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={withBase('favicon.svg')} />
		<link rel="icon" href={withBase('favicon.ico')} sizes="any" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{pageTitle}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,700&family=Noto+Sans:ital,wght@0,400;0,600;1,400&family=Noto+Sans+SC:wght@400;600&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<div class="page-shell">
			<header class="site-header">
				<a class="brand" href={withBase()}>GlobalPulse</a>
				<nav class="site-nav" aria-label="Primary">
					<a href={withBase()}>Today</a>
					<a href={withBase('archive')}>Archive</a>
					<a
						class="site-nav__github"
						href="https://github.com/b0x1/globalpulse"
						aria-label="GlobalPulse on GitHub"
					>
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" aria-hidden="true">
							<path
								fill="currentColor"
								d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.438 1.236 1.438 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
							></path>
						</svg>
					</a>
				</nav>
			</header>
			<main>
				<slot />
			</main>
			<footer class="site-footer">
				<p>
					Automated news aggregation from around the world. Content on this site is compiled
					automatically from third-party sources and is not independently verified. We make no
					representation or warranty as to the accuracy, completeness, or timeliness of any
					information shown here. Links to external websites are provided for convenience only; we
					do not control those sites and accept no responsibility or liability for their content or
					for any loss or damage arising from your use of this site or of linked third-party
					material.
				</p>
				<p class="site-footer__credit">
					© {siteContact.name}, {siteContact.location}
				</p>
				<p class="site-footer__legal">
					<a href="https://docs.github.com/en/site-policy/privacy-policies/github-general-privacy-statement">Privacy Statement</a>
				</p>
			</footer>
		</div>
	</body>
</html>
