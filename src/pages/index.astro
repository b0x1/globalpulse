---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsByRegion from '../components/NewsByRegion.astro';
import NewsFilters from '../components/NewsFilters.astro';
import { collectFilterOptions, getPublishedNews, groupByRegion } from '../lib/news';

const news = await getPublishedNews();
const regions = groupByRegion(news);
const filters = collectFilterOptions(news);
---

<BaseLayout title="GlobalPulse">
	<p class="lede">News in English, German, Chinese, and French — from the language of the land.</p>

	{regions.length > 0 && <NewsFilters options={filters} />}

	<NewsByRegion
		regions={regions}
		showDate
		empty="No stories yet. Add Markdown files under src/content/news/YYYY-MM-DD/."
		idPrefix="continent"
	/>
</BaseLayout>
