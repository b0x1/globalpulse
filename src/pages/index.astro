---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsByRegion from '../components/NewsByRegion.astro';
import NewsFilters from '../components/NewsFilters.astro';
import {
	collectFilterOptions,
	dateKey,
	getPublishedNews,
	groupByRegion,
} from '../lib/news';
import { siteTagline } from '../lib/site';

const today = dateKey(new Date());
const news = (await getPublishedNews()).filter(
	(entry) => dateKey(entry.data.date) === today,
);
const regions = groupByRegion(news);
const filters = collectFilterOptions(news);
---

<BaseLayout title="GlobalPulse">
	<p class="lede lede--tagline">{siteTagline}</p>

	{regions.length > 0 && <NewsFilters options={filters} />}

	<NewsByRegion
		regions={regions}
		showDate
		empty="No stories for today yet. Add Markdown files under src/content/news/YYYY-MM-DD/."
		idPrefix="continent"
	/>
</BaseLayout>
